{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/schemas/config/wrangler.json",
  "name": "clawdle",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2026-03-11",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "clawdle.nard.uk",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "clawdle-db",
      "database_id": "a501785e-af2c-4bda-9845-3af8b365b7fe"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "2641048c87814b19a2d2e016ba4e9a2c",
      "preview_id": "3e56a5e51b474eabb8e97c8f73f62c9f"
    }
  ]
}
