{
  "name": "clawdle",
  "version": "1.11.14",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "quality": "pnpm run quality:fix && pnpm run quality:check",
    "clean": "find . -type d \\( -name node_modules -o -name .nuxt -o -name .output -o -name .nitro -o -name .wrangler -o -name .turbo -o -name .data -o -name dist \\) -not -path './.git/*' -prune -exec rm -rf {} +",
    "clean:install": "pnpm run clean && if [ -n \"${NARDUK_PLATFORM_GH_PACKAGES_READ:-${NARDUK_PLATFORM_GH_PACKAGES_RW:-}}\" ]; then pnpm run package-registry:auth && NPM_CONFIG_USERCONFIG=\"$PWD/.npmrc.auth\" NPM_CONFIG_GLOBALCONFIG=/dev/null pnpm install; else pnpm install; fi && pnpm --filter web run db:ready",
    "db:migrate": "pnpm --filter web run db:migrate",
    "dev:kill": "sh scripts/dev-kill.sh",
    "test:e2e": "playwright test",
    "generate:favicons": "pnpm exec narduk-starter-toolkit generate-favicons",
    "predev": "pnpm exec narduk-starter-toolkit check-setup",
    "prebuild": "pnpm exec narduk-starter-toolkit check-setup",
    "preship": "pnpm exec narduk-starter-toolkit check-setup && if [ -n \"${NARDUK_PLATFORM_GH_PACKAGES_READ:-${NARDUK_PLATFORM_GH_PACKAGES_RW:-}}\" ]; then pnpm run package-registry:auth && NPM_CONFIG_USERCONFIG=\"$PWD/.npmrc.auth\" NPM_CONFIG_GLOBALCONFIG=/dev/null pnpm install; else pnpm install; fi && pnpm audit --audit-level=critical && pnpm run quality:check && pnpm -r --if-present test:unit",
    "postinstall": "pnpm exec narduk-starter-toolkit postinstall",
    "format": "prettier --write \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\"",
    "quality:fix": "turbo run lint --force -- --fix && pnpm run format",
    "hooks:install": "pnpm exec narduk-starter-toolkit install-git-hooks",
    "quality:check": "turbo run quality --filter='./apps/*'",
    "check": "pnpm run quality:check",
    "cleanup:node-leaks": "sh scripts/cleanup-node-leaks.sh",
    "test:e2e:web": "pnpm --filter web test:e2e",
    "package-registry:auth": "node scripts/package-registry-auth.mjs",
    "sync:skills": "narduk-skills sync --clean"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "serialize-javascript": ">=7.0.5",
      "@cloudflare/unenv-preset": "2.12.1",
      "@takumi-rs/core": ">=0.70.1",
      "@takumi-rs/wasm": ">=0.70.1",
      "archiver-utils": "file:vendor/archiver-utils",
      "@cloudflare/workers-types": "4.20260307.1",
      "@typescript-eslint/utils": "^8.57.0",
      "@nuxt/eslint": "^1.15.2",
      "nuxt-og-image": "6.3.3",
      "eslint-plugin-unicorn": "^63.0.0",
      "svgo": "4.0.1",
      "tar": "7.5.11",
      "flatted": "3.4.2",
      "node-forge": "1.4.0",
      "defu": "6.1.5",
      "@eslint/config-inspector>h3": "1.15.9",
      "@stylistic/eslint-plugin>picomatch": "4.0.4",
      "vite>picomatch": "4.0.4",
      "micromatch>picomatch": "2.3.2",
      "listhen>h3": "1.15.9",
      "@nuxt/image>h3": "1.15.9",
      "@nuxt/fonts>h3": "1.15.9",
      "nuxt-auth-utils>h3": "1.15.9",
      "@nuxt/test-utils>h3": "2.0.1-rc.18",
      "@nuxt/test-utils>h3-next": "npm:h3@2.0.1-rc.18",
      "anymatch>picomatch": "2.3.2",
      "tinyglobby>picomatch": "4.0.4",
      "unplugin>picomatch": "4.0.4",
      "unplugin-utils>picomatch": "4.0.4",
      "unimport>picomatch": "4.0.4",
      "vitest>picomatch": "4.0.4",
      "@vue/language-core>picomatch": "4.0.4",
      "vite>yaml": "2.8.3",
      "yaml": "2.8.3",
      "minimatch@3>brace-expansion": "1.1.13",
      "minimatch@5>brace-expansion": "2.0.3",
      "minimatch@9>brace-expansion": "2.0.3",
      "minimatch@10>brace-expansion": "5.0.5"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ],
    "peerDependencyRules": {
      "allowAny": [
        "eslint",
        "citty",
        "@cloudflare/workers-types"
      ]
    },
    "patchedDependencies": {}
  },
  "volta": {
    "node": "22.22.0"
  },
  "devDependencies": {
    "@narduk-enterprises/narduk-cli": "^1.18.6",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.19.13",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "turbo": "^2.8.12",
    "@narduk-enterprises/narduk-starter-toolkit": "^1.17.2",
    "@narduk-enterprises/narduk-skills": "0.3.0",
    "wait-on": "^9.0.4"
  }
}
